{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://second-life-commerce.onrender.com/api/$1"
    },
    {
      "source": "/static/(.*)",
      "destination": "https://second-life-commerce.onrender.com/static/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
